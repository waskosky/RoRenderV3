{
  "name": "rorender-v3-rai",
  "version": "3.1.0",
  "private": true,
  "description": "A security-conscious, headless-compatible orthographic map renderer for Roblox experiences, based on RoRenderV3",
  "main": "main.js",
  "type": "commonjs",
  "bin": {
    "rorender": "bin/rorender.js"
  },
  "exports": {
    ".": "./lib/server.js",
    "./config": "./lib/config.js",
    "./protocol": "./lib/protocol.js"
  },
  "author": "A.J. Steinhauser",
  "contributors": [
    "Waskosky RoRenderV3 fork maintainers"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/waskosky/RoRenderV3.git"
  },
  "homepage": "https://github.com/waskosky/RoRenderV3",
  "bugs": {
    "url": "https://github.com/waskosky/RoRenderV3/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "serve": "node bin/rorender.js serve",
    "doctor": "node bin/rorender.js doctor",
    "test": "node --test",
    "validate": "node scripts/validate-package.js && node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.waskosky.rorender.v3",
    "productName": "RoRenderV3",
    "asar": true,
    "files": [
      "bin/**/*",
      "css/**/*",
      "img/**/*",
      "index.html",
      "lib/**/*",
      "main.js",
      "preload.js",
      "renderer.js",
      "LICENSE",
      "NOTICE.md",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "./img/icons/mac/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "./img/icons/win/icon.ico",
      "legalTrademarks": "Open Source"
    }
  }
}
